# ── GCP Configuration ──
GCP_PROJECT_ID=nytia-dev
BQ_DATASET=wellness_data
BQ_RAW_TABLE=bronze_assessments
BQ_SILVER_TABLE=silver_validated
BQ_GOLD_TABLE=gold_features
GCS_BUCKET=nytia-dev-ml-artifacts
GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcp_service_account.json

# ── Environment ──
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── Model ──
MODEL_PATH=/app/models/artifacts/

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000

# ── Data Paths (local fallback) ──
RAW_DATA_PATH=/app/data/raw/
PROCESSED_DATA_PATH=/app/data/processed/
SAMPLE_DATA_PATH=/app/data/sample/
